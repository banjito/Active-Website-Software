# ampOS (Supabase) — bid-side access. Values are NOT secrets to commit; the real
# rotating refresh token lives OUTSIDE this folder at %USERPROFILE%\.ampos-tokens\.env
# (managed by ampos_auth.py). The anon key is the app's PUBLIC publishable key.
AMPOS_ANON=<supabase anon/publishable JWT — baked into the ampOS web bundle>

# Stored automatically by ampos_auth.py in %USERPROFILE%\.ampos-tokens\.env :
#   AMPOS_REFRESH_TOKEN=<rotates each use>
#   AMPOS_ACCESS_TOKEN=<minted, ~1h>
#   AMPOS_EXPIRES_AT=<unix seconds>

# QuickBooks Online (AMPQES) — handled by the shared CLI, tokens in ~/.qbo-tokens/.env
#   node qbo.js --client ampqes ...   (read-only Accounting scope)
# Realm: 123145887114114
